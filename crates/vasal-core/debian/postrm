#!/bin/sh
set -e

case "$1" in
    purge)
        # Remove state, cache, and runtime directories on purge.
        rm -rf /var/lib/vasal
        rm -rf /var/cache/vasal
        rm -rf /run/vasal

        # Remove the system user and group.
        if getent passwd vasal >/dev/null 2>&1; then
            userdel vasal || true
        fi
        if getent group vasal >/dev/null 2>&1; then
            groupdel vasal || true
        fi
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument: $1" >&2
        exit 1
        ;;
esac

systemctl daemon-reload

#DEBHELPER#
